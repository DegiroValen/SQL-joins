<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path=":memory:" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser query pragmas" current="2"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="990"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="long-run-birth-rate" custom_title="0" dock_id="1" table="4,19:mainlong-run-birth-rate"/><dock_state state="000000ff00000000fd00000001000000020000057a00000381fc0100000001fb000000160064006f0063006b00420072006f007700730065003101000000000000057a0000011700ffffff000002dd0000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="children-born-per-woman" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="159"/><column index="2" value="71"/><column index="3" value="43"/><column index="4" value="118"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="infant-mortality" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="159"/><column index="2" value="71"/><column index="3" value="43"/><column index="4" value="135"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="long-run-birth-rate" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="159"/><column index="2" value="48"/><column index="3" value="43"/><column index="4" value="79"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="population-density" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort><column index="3" mode="1"/></sort><column_widths><column index="1" value="95"/><column index="2" value="48"/><column index="3" value="55"/><column index="4" value="124"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="sales-of-cigarettes-per-adult-per-day" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort><column index="3" mode="0"/></sort><column_widths><column index="1" value="183"/><column index="2" value="71"/><column index="3" value="43"/><column index="4" value="292"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">WITH tabla as (

SELECT pd.Entity,pd.Year, pd.&quot;Population density&quot;, cbpw.&quot;Total fertility rate&quot; from &quot;population-density&quot; as pd

INNER JOIN &quot;children-born-per-woman&quot; as cbpw

on pd.Entity = cbpw.Entity and pd.Year = cbpw.Year

)

SELECT t.Entity ,t.Year, t.&quot;Population density&quot;, t.&quot;Total fertility rate&quot;, im.&quot;Infant mortality rate&quot;, sc.&quot;Manufactured cigarette sales per adult per day&quot;, br.&quot;Birth rate&quot; from tabla as t

LEFT join &quot;infant-mortality&quot; as im

on t.Entity = im.Entity and t.Year = im.Year



left join &quot;sales-of-cigarettes-per-adult-per-day&quot; as sc

on t.Entity = sc.Entity and t.Year = sc.Year



left join &quot;long-run-birth-rate&quot; as br

on t.Entity = br.Entity and t.Year = br.Year</sql><current_tab id="0"/></tab_sql></sqlb_project>
